{
  "_meta": {
    "version": "1.0.0",
    "description": "Global component registry. Agents MUST check this before creating any component. Never duplicate what exists here.",
    "usage": "Read this file first. Find matching component by category and name. Use the template path to get the code."
  },
  "web": {
    "navigation": {
      "navbar": {
        "description": "Responsive top navigation bar with logo, links, mobile hamburger menu",
        "template": "components/web/navigation/navbar.md",
        "props": ["logo", "links", "cta", "sticky", "transparent"],
        "variants": ["default", "centered", "sidebar-toggle"],
        "responsive": true
      },
      "sidebar": {
        "description": "Collapsible sidebar navigation for dashboards and admin panels",
        "template": "components/web/navigation/sidebar.md",
        "props": ["items", "collapsed", "logo", "footer"],
        "variants": ["default", "mini", "overlay"],
        "responsive": true
      },
      "breadcrumb": {
        "description": "Breadcrumb navigation showing page hierarchy",
        "template": "components/web/navigation/breadcrumb.md",
        "props": ["items", "separator"],
        "variants": ["default", "with-icons"],
        "responsive": true
      },
      "footer": {
        "description": "Site footer with links, social icons, newsletter signup",
        "template": "components/web/navigation/footer.md",
        "props": ["columns", "social", "newsletter", "copyright"],
        "variants": ["simple", "multi-column", "centered"],
        "responsive": true
      },
      "tabs": {
        "description": "Tab navigation for switching between content sections",
        "template": "components/web/navigation/tabs.md",
        "props": ["items", "activeTab", "onChange", "orientation"],
        "variants": ["default", "pills", "underline"],
        "responsive": true
      }
    },
    "forms": {
      "input": {
        "description": "Text input field with label, validation, error message",
        "template": "components/web/forms/input.md",
        "props": ["label", "type", "placeholder", "error", "required", "disabled"],
        "variants": ["default", "floating-label", "with-icon"],
        "responsive": true
      },
      "select": {
        "description": "Dropdown select with search, multi-select support",
        "template": "components/web/forms/select.md",
        "props": ["options", "label", "multiple", "searchable", "placeholder"],
        "variants": ["default", "multi", "grouped"],
        "responsive": true
      },
      "checkbox": {
        "description": "Checkbox and checkbox group with labels",
        "template": "components/web/forms/checkbox.md",
        "props": ["label", "checked", "onChange", "disabled", "indeterminate"],
        "variants": ["default", "switch", "card"],
        "responsive": true
      },
      "textarea": {
        "description": "Multi-line text input with auto-resize",
        "template": "components/web/forms/textarea.md",
        "props": ["label", "rows", "maxLength", "autoResize", "placeholder"],
        "variants": ["default", "rich-text"],
        "responsive": true
      },
      "file-upload": {
        "description": "File upload with drag-and-drop, preview, progress bar",
        "template": "components/web/forms/file-upload.md",
        "props": ["accept", "maxSize", "multiple", "onUpload"],
        "variants": ["default", "dropzone", "avatar"],
        "responsive": true
      },
      "form-wrapper": {
        "description": "Form container with validation, submit handling, field layout",
        "template": "components/web/forms/form-wrapper.md",
